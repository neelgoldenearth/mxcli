-- ============================================================================
-- Microflow Examples - Comprehensive Parser Feature Showcase
-- ============================================================================
--
-- This file demonstrates all microflow features currently supported by the
-- Mendix REPL parser, organized by increasing complexity.
--
-- Usage:
--   1. Connect to your project
--   2. Execute: EXECUTE SCRIPT 'examples/microflow-examples.mdl';
--   3. MfTest roundtrip with: DESCRIBE MICROFLOW MfTest.MicroflowName;
--
-- ============================================================================

-- MARK: Entities

CREATE MODULE MfTest;
-- ============================================================================
-- Setup: Create MfTest Entities
-- ============================================================================

/**
 * Country codes with full names as captions.
 */
CREATE ENUMERATION MfTest.Country (
  /** United States */
  US 'United States',
  /** United Kingdom */
  UK 'United Kingdom',
  /** Germany */
  DE 'Germany',
  /** France */
  FR 'France',
  /** Netherlands */
  NL 'Netherlands',
  /** Japan */
  JP 'Japan',
  /** Australia */
  AU 'Australia'
);
/

-- Create entities used by microflow examples
@Position(100,100)
CREATE PERSISTENT ENTITY MfTest.Product (
  Name: String(200) NOT NULL,
  Code: String(50),
  IsActive: Boolean DEFAULT true,
  CreateDate: DateTime,
  Price: Decimal,
  ModifiedDate: DateTime,
  MonthlyTotal: Decimal,
  DailyAverage: Decimal,
  LastProcessedDate: DateTime,
  LastCalculated: DateTime
);

@Position(300,100)
CREATE PERSISTENT ENTITY MfTest.Customer (
  Name: String(200) NOT NULL,
  Email: String(200),
  Code: String(50),
  Phone: String(50),
  Address: String(500),
  City: String(100),
  Country: Enumeration(MfTest.Country),
  IsActive: Boolean DEFAULT true,
  CreateDate: DateTime
);

@Position(500,100)
CREATE PERSISTENT ENTITY MfTest.Order (
  OrderNumber: String(50) NOT NULL,
  OrderDate: DateTime,
  TotalAmount: Decimal,
  Status: String(50),
  ProcessedDate: DateTime,
  Quantity: Integer,
  TotalPrice: Decimal,
  CreateDate: DateTime
);

-- Create associations
CREATE ASSOCIATION MfTest.Order_Customer
FROM MfTest.Order TO MfTest.Customer
TYPE Reference
OWNER Both;

CREATE ASSOCIATION MfTest.Order_Product
FROM MfTest.Order TO MfTest.Product
TYPE Reference
OWNER Both;

-- MARK: BASIC MF
-- ============================================================================
-- LEVEL 1: Basic Microflows
-- ============================================================================

/**
 * Example 1.1: Simplest possible microflow
 * Minimal microflow demonstrating basic structure
 */
CREATE MICROFLOW MfTest.M001_HelloWorld ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = true;
  RETURN $Success;
END;
/

/**
 * Example 1.1: Simplest possible microflow
 * Minimal microflow demonstrating basic structure
 */
CREATE or replace MICROFLOW MfTest.M001_HelloWorld ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = true;
  LOG TRACE NODE 'TEST' 'List received '
  RETURN $Success;
END;
/

/**
 * Example 1.1: Simplest possible microflow
 * Minimal microflow demonstrating basic structure
 */
CREATE or replace MICROFLOW MfTest.M001_HelloWorld_1 ()
RETURNS Boolean AS $Success
BEGIN
  CALL MICROFLOW MfTest.M001_HelloWorld();
  Return true;
END;
/

/**
 * Example 1.1: Simplest possible microflow
 * Minimal microflow demonstrating basic structure
 */
CREATE or replace MICROFLOW MfTest.M001_HelloWorld ()
RETURNS Boolean AS $Success
BEGIN
  LOG TRACE NODE 'TEST' '> before'
  DECLARE $Success Boolean = true;
  LOG TRACE NODE 'TEST' '< After'
  RETURN $Success;
END;
/

/**
 * Example 1.1.1: Simplest possible microflow
 * Minimal microflow demonstrating basic structure with folder
 */
CREATE MICROFLOW MfTest.M001_HelloWorld_2 ()
RETURNS Boolean AS $Success
FOLDER 'microflows/basic'
BEGIN
  DECLARE $Success Boolean = true;
  RETURN $Success;
END;
/

/**
 * Demonstrates variable declaration and arithmetic
 */
CREATE MICROFLOW MfTest.M002_BasicVariables ()
RETURNS Integer AS $Result
BEGIN
  DECLARE $Result Integer = 0;
  DECLARE $Counter Integer = 0;
  DECLARE $Multiplier Integer = 5;

  SET $Counter = $Counter + 10;
  SET $Result = $Counter * $Multiplier;

  RETURN $Result;
END;
/

/**
 * String concatenation and manipulation
 */
CREATE MICROFLOW MfTest.M003_StringOperations (
  $FirstName: String,
  $LastName: String
)
RETURNS String AS $FullName
BEGIN
  DECLARE $FullName String = $FirstName + ' ' + $LastName;
  RETURN $FullName;
END;
/

/**
 * Example 1.4: Boolean logic
 *
 * Demonstrates boolean operations.
 */
CREATE MICROFLOW MfTest.M004_BooleanLogic (
  $IsActive: Boolean,
  $IsValid: Boolean
)
RETURNS Boolean AS $CanProceed
BEGIN
  DECLARE $CanProceed Boolean = $IsActive AND $IsValid;
  RETURN $CanProceed;
END;
/

/**
 * Demonstrates list of entity parameter type
 *
 * @param ProductList a list of MfTest.Product
 */
CREATE MICROFLOW MfTest.M005_1_LogParameter (
  $ProductList: List of MfTest.Product
)
BEGIN
  LOG INFO NODE 'TEST' 'List received';
END;
/

/**
 * Demonstrates list of entity parameter type
 *
 * @param ProductList a list of MfTest.Product
 */
CREATE MICROFLOW MfTest.M005_2_LogParameter (
  $ProductList: List of MfTest.Product  
)
BEGIN
  LOG INFO NODE 'TEST' 'List received ' + 'abc';
END;
/

/**
 * Demonstrates list of entity parameter type
 *
 * @param ProductList a list of MfTest.Product
 */
CREATE MICROFLOW MfTest.M005_3_LogParameter (
  $ProductList: List of MfTest.Product
)
BEGIN
  LOG TRACE NODE 'TEST' 'List received ' + 'abc' + 'def';
  LOG DEBUG NODE 'TEST' 'List received ' + 'abc' + 'def';
  LOG INFO NODE 'TEST' 'List received ' + 'abc' + 'def';
  LOG WARNING NODE 'TEST' 'List received ' + 'abc' + 'def';
  LOG ERROR NODE 'TEST' 'List received ' + 'abc' + 'def';
  LOG CRITICAL NODE 'TEST' 'List received ' + 'abc' + 'def';
END;
/

-- ============================================================================
-- LEVEL 2: Control Flow
-- ============================================================================

/**
 * Basic conditional logic with IF/THEN/END IF
 */
CREATE MICROFLOW MfTest.M006_SimpleIf (
  $Value: Integer
)
RETURNS String AS $Message
BEGIN
  DECLARE $Message String = 'Unknown';

  IF $Value > 10 THEN
    SET $Message = 'Value is greater than 10';
  END IF;

  RETURN $Message;
END;
/

/**
 * Example 2.2: IF/THEN/ELSE
 *
 * Conditional with ELSE clause.
 */
CREATE MICROFLOW MfTest.M007_IfElse (
  $Value: Integer
)
RETURNS String AS $Category
BEGIN
  DECLARE $Category String = empty;

  IF $Value > 100 THEN
    SET $Category = 'High';
  ELSE
    SET $Category = 'Low';
  END IF;

  RETURN $Category;
END;
/

/**
 * Example 2.3: Nested IF statements
 *
 * Nested conditional logic.
 *
 * @param Score The input score value
 * @returns Grade string (A, B, C, or F)
 */
CREATE MICROFLOW MfTest.M008_NestedIf (
  $Score: Integer
)
RETURNS String AS $Grade
BEGIN
  DECLARE $Grade String = 'F';

  IF $Score >= 90 THEN
    SET $Grade = 'A';
  ELSE
    IF $Score >= 80 THEN
      SET $Grade = 'B';
    ELSE
      IF $Score >= 70 THEN
        SET $Grade = 'C';
      ELSE
        SET $Grade = 'F';
      END IF;
    END IF;
  END IF;

  RETURN $Grade;
END;
/

-- ============================================================================
-- LEVEL 3: Logging and Expressions
-- ============================================================================

/**
 * Example 3.1: LOG statements
 *
 * Demonstrates logging at different levels.
 */
CREATE MICROFLOW MfTest.M009_Logging (
  $OrderNumber: String
)
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = true;
  LOG INFO NODE 'TEST' 'Starting order processing';
  LOG INFO NODE 'OrderService' 'Processing order: ' + $OrderNumber;
  LOG WARNING NODE 'TEST' 'This is a warning message';
  RETURN $Success;
END;
/

/**
 * Example 3.2: LOG with String template parameters
 *
 * Demonstrates LOG with template placeholders {1}, {2}, etc.
 * The WITH clause maps placeholders to expressions using the unified template syntax.
 * This is more efficient than string concatenation for logging.
 *
 * Note: Pages use the same WITH syntax for DynamicText and ActionButton captions.
 * See docs/03-development/STRING_TEMPLATE_SYNTAX.md for full specification.
 */
CREATE MICROFLOW MfTest.M009_2_LogWithTemplate (
  $OrderNumber: String,
  $CustomerName: String,
  $TotalAmount: Decimal
)
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = true;
  DECLARE $ItemCount Integer = 5;

  -- Simple template with one parameter
  LOG INFO NODE 'OrderService' 'Processing order: {1}' WITH ({1} = $OrderNumber);

  -- Template with multiple parameters of different types
  LOG INFO NODE 'OrderService' 'Order {1} for customer {2} with {3} items totaling {4}' WITH (
    {1} = $OrderNumber,
    {2} = $CustomerName,
    {3} = toString($ItemCount) ,
    {4} = toString($TotalAmount) 
  );

  -- Warning with template
  LOG WARNING NODE 'OrderService' 'High value order detected: {1} = {2}' WITH (
      {1} = toString($OrderNumber)
    , {2} = toString($TotalAmount)
  );

  RETURN $Success;
END;
/

/**
 * Example 3.3: Arithmetic expressions with div
 *
 * Demonstrates div operator for division.
 */
CREATE MICROFLOW MfTest.M010_ArithmeticOperations (
  $Total: Decimal,
  $Count: Integer
)
RETURNS Decimal AS $Average
BEGIN
  DECLARE $Average Decimal = 0;
  SET $Average = $Total div $Count;
  RETURN $Average;
END;
/

/**
 * Example 3.4: Complex arithmetic
 *
 * Complex arithmetic with multiple operators.
 */
CREATE MICROFLOW MfTest.M011_ComplexMath (
  $Principal: Decimal,
  $Rate: Decimal,
  $Time: Integer
)
RETURNS Decimal AS $Interest
BEGIN
  DECLARE $RateDecimal Decimal = $Rate div 100;
  DECLARE $Interest Decimal = $Principal * $RateDecimal * $Time;
  RETURN $Interest;
END;
/

-- MARK: Object Ops

-- ============================================================================
-- LEVEL 4: Object Operations
-- ============================================================================

/**
 * Example 4.1: CREATE object
 *
 * Creates a new entity object.
 */
CREATE MICROFLOW MfTest.M012_CreateEntity (
  $Name: String,
  $Code: String
)
RETURNS MfTest.Product AS $NewProduct
BEGIN
  $NewProduct = CREATE MfTest.Product (
    Name = $Name,
    Code = $Code,
    IsActive = true,
    CreateDate = [%CurrentDateTime%]);

  RETURN $NewProduct;
END;
/

/**
 * Example 4.2: COMMIT operations
 *
 * Demonstrates COMMIT with and without events.
 */
CREATE MICROFLOW MfTest.M013_SaveEntity (
  $Product: MfTest.Product
)
RETURNS Boolean AS $Success
BEGIN
  -- Commit without events
  COMMIT $Product;

  LOG INFO NODE 'TEST' 'Entity saved';
  DECLARE $Success Boolean = true;
  RETURN $Success;
END;
/

/**
 * Example 4.3: COMMIT WITH EVENTS
 *
 * Commit that triggers event handlers.
 */
CREATE MICROFLOW MfTest.M014_SaveEntityWithEvents (
  $Product: MfTest.Product
)
RETURNS Boolean AS $Success
BEGIN
  COMMIT $Product WITH EVENTS;

  LOG INFO NODE 'Test' 'Entity saved with events';
  DECLARE $Success Boolean = true;
  RETURN $Success;
END;
/

/**
 * Example 4.4: CHANGE object
 *
 * Updates entity attributes.
 */
CREATE MICROFLOW MfTest.M015_UpdateEntity (
  $Product: MfTest.Product,
  $NewName: String
)
RETURNS Boolean AS $Success
BEGIN
  CHANGE $Product (
    Name = $NewName,
    ModifiedDate = [%CurrentDateTime%]);

  COMMIT $Product WITH EVENTS;

  DECLARE $Success Boolean = true;
  RETURN $Success;
END;
/

/**
 * Creates a new entity object
 */
CREATE MICROFLOW MfTest.M015_2_CreateUpdateEntity (
  $Name: String,
  $Code: String
)
RETURNS MfTest.Product AS $NewProduct
BEGIN
  $NewProduct = CREATE MfTest.Product (
    Name = $Name,
    Code = $Code,
    IsActive = true,
    CreateDate = [%CurrentDateTime%]);

  CHANGE $NewProduct (
    Name = $Name + 'Changed',
    ModifiedDate = [%CurrentDateTime%]);

  RETURN $NewProduct;
END;
/

-- MARK: XPath

-- ============================================================================
-- LEVEL 5: XPath Navigation (NEW FEATURE!)
-- ============================================================================

/**
 * Example 5.1: XPath attribute access
 *
 * Access attributes using XPath-style paths.
 */
CREATE MICROFLOW MfTest.M016_XPathAttributeAccess (
  $Product: MfTest.Product
)
RETURNS String AS $ProductName
BEGIN
  DECLARE $ProductName String = $Product/Name;
  RETURN $ProductName;
END;
/

/**
 * Example 5.2: CHANGE object attributes
 *
 * Modify entity attributes using CHANGE statement.
 */
CREATE MICROFLOW MfTest.M017_XPathSetAttribute (
  $Product: MfTest.Product,
  $NewPrice: Decimal
)
RETURNS Boolean AS $Success
BEGIN
  CHANGE $Product (Price = $NewPrice);
  CHANGE $Product (ModifiedDate = [%CurrentDateTime%]);

  COMMIT $Product;
  DECLARE $Success Boolean = true;
  RETURN $Success;
END;
/

/**
 * Example 5.3: XPath association navigation
 *
 * Navigate associations using XPath.
 */
CREATE MICROFLOW MfTest.M018_XPathAssociationNav (
  $Order: MfTest.Order
)
RETURNS String AS $CustomerName
BEGIN
  DECLARE $CustomerName String = $Order/MfTest.Order_Customer/MfTest.Customer/Name;
  RETURN $CustomerName;
END;
/

/**
 * Example 5.4: CHANGE association
 *
 * Set associations using CHANGE statement with fully qualified association name.
 */
CREATE MICROFLOW MfTest.M019_XPathQualifiedAssociation (
  $Order: MfTest.Order,
  $Customer: MfTest.Customer
)
RETURNS Boolean AS $Success
BEGIN
  CHANGE $Order (MfTest.Order_Customer = $Customer);
  COMMIT $Order;

  DECLARE $Success Boolean = true;
  RETURN $Success;
END;
/

/**
 * Example 5.5: XPath in expressions with div
 *
 * Combines XPath navigation with div operator.
 */
CREATE MICROFLOW MfTest.M020_XPathWithDiv (
  $Product: MfTest.Product
)
RETURNS Decimal AS $DailyAverage
BEGIN
  DECLARE $MonthlyTotal Decimal = $Product/MonthlyTotal;
  DECLARE $DailyAverage Decimal = $MonthlyTotal div 30;
  RETURN $DailyAverage;
END;
/
-- MARK: loops

-- ============================================================================
-- LEVEL 6: Loops
-- ============================================================================

/**
 * Example 6.1: Simple LOOP over list
 *
 * Basic loop over collection.
 */
CREATE MICROFLOW MfTest.M021_SimpleLoop (
  $ProductList: List of MfTest.Product
)
RETURNS Integer AS $Count
BEGIN
  DECLARE $Count Integer = 0;

  LOOP $Product IN $ProductList
  BEGIN
    SET $Count = $Count + 1;
  END LOOP;

  RETURN $Count;
END;
/

/**
 * Example 6.2: LOOP with object modification
 *
 * Loop that modifies each object.
 */
CREATE MICROFLOW MfTest.M022_LoopWithChange (
  $ProductList: List of MfTest.Product
)
RETURNS Integer AS $UpdatedCount
BEGIN
  DECLARE $UpdatedCount Integer = 0;

  LOOP $Product IN $ProductList
  BEGIN
    CHANGE $Product (IsActive = true);
    COMMIT $Product;
    SET $UpdatedCount = $UpdatedCount + 1;
  END LOOP;

  RETURN $UpdatedCount;
END;
/

/**
 * Example 6.3: LOOP with conditional logic
 *
 * Loop with IF statement inside.
 */
CREATE MICROFLOW MfTest.M023_LoopWithCondition (
  $ProductList: List of MfTest.Product
)
RETURNS Integer AS $ActiveCount
BEGIN
  DECLARE $ActiveCount Integer = 0;

  LOOP $Product IN $ProductList
  BEGIN
    IF $Product/IsActive THEN
      SET $ActiveCount = $ActiveCount + 1;
      LOG INFO NODE 'Test' 'Found active product';
    END IF;
  END LOOP;

  RETURN $ActiveCount;
END;
/

/**
 * Example 6.4: Nested loops
 *
 * Nested loop iteration.
 */
CREATE MICROFLOW MfTest.M024_NestedLoops (
  $OrderList: List of MfTest.Order
)
RETURNS Integer AS $TotalLineItems
BEGIN
  DECLARE $TotalLineItems Integer = 0;

  LOOP $Order IN $OrderList
  BEGIN
    LOG INFO NODE 'Test' 'Processing order';
    RETRIEVE $CustomerList FROM MfTest.Customer
    WHERE MfTest.Order_Customer = $Order;
    LOOP $Customer IN $CustomerList
    BEGIN
      LOG INFO NODE 'Test' 'Processing Customer';
    END LOOP;
    SET $TotalLineItems = $TotalLineItems + 1;
  END LOOP;

  RETURN $TotalLineItems;
END;
/

/**
 * Example 6.5: DECLARE inside LOOP body
 *
 * Demonstrates declaring local variables inside a loop.
 * Each iteration creates a temporary variable for intermediate calculations.
 */
CREATE MICROFLOW MfTest.M024_2_DeclareInLoop (
  $ProductList: List of MfTest.Product
)
RETURNS Decimal AS $TotalDiscounted
BEGIN
  DECLARE $TotalDiscounted Decimal = 0;

  LOOP $Product IN $ProductList
  BEGIN
    DECLARE $OriginalPrice Decimal = $Product/Price;
    DECLARE $Discount Decimal = $OriginalPrice * 0.1;
    DECLARE $DiscountedPrice Decimal = $OriginalPrice - $Discount;
    SET $TotalDiscounted = $TotalDiscounted + $DiscountedPrice;
  END LOOP;

  RETURN $TotalDiscounted;
END;
/

-- ============================================================================
-- LEVEL 7: RETRIEVE (Database Queries)
-- ============================================================================

/**
 * Example 7.1: Simple RETRIEVE
 *
 * Basic database query.
 */
CREATE MICROFLOW MfTest.M025_SimpleRetrieve ()
RETURNS List of MfTest.Product AS $ProductList
BEGIN
  RETRIEVE $ProductList FROM MfTest.Product;
  RETURN $ProductList;
END;
/

/**
 * Example 7.2: RETRIEVE with WHERE clause
 *
 * Query with filter condition.
 */
CREATE MICROFLOW MfTest.M026_RetrieveWithWhere (
  $SearchCode: String
)
RETURNS List of MfTest.Product AS $ProductList
BEGIN
  RETRIEVE $ProductList FROM MfTest.Product
    WHERE Code = $SearchCode;
  RETURN $ProductList;
END;
/

/**
 * Example 7.3: RETRIEVE with multiple conditions
 *
 * Query with AND conditions.
 */
CREATE MICROFLOW MfTest.M027_RetrieveMultipleConditions ()
RETURNS List of MfTest.Product AS $ProductList
BEGIN
  RETRIEVE $ProductList FROM MfTest.Product
    WHERE IsActive = true
      AND Price > 100;

  RETURN $ProductList;
END;
/

/**
 * Example 7.3b: RETRIEVE with multiple conditions
 *
 * Query with AND conditions.
 */
CREATE MICROFLOW MfTest.M027_2_RetrieveMultipleConditions ()
RETURNS List of MfTest.Product AS $ProductList
BEGIN
  RETRIEVE $ProductList FROM MfTest.Product
    WHERE (
      IsActive = true()
      and contains(Code, 'a')
      and Price > 10
    ) or (
      DailyAverage < 2
    )
    SORT BY MfTest.Product.Name ASC, MfTest.Product.Price DESC
    LIMIT 10 OFFSET 5 ;

  RETURN $ProductList;
END;
/

/**
 * Example 7.4: RETRIEVE single object
 *
 * Query returning single object.
 */
CREATE MICROFLOW MfTest.M028_RetrieveSingleObject (
  $ProductCode: String
)
RETURNS MfTest.Product AS $Product
BEGIN
  RETRIEVE $Product FROM MfTest.Product
    WHERE Code = $ProductCode
    LIMIT 1;
  RETURN $Product;
END;
/

CREATE MICROFLOW MfTest.M028_DataForm_Getter_2 ()
RETURNS MfTest.Customer AS $FirstCustomer
BEGIN
  RETRIEVE $CustomerList FROM MfTest.Customer
    WHERE ( starts-with(Name, 'a') )
    LIMIT 2 OFFSET 3;
  SET $FirstCustomer = HEAD($CustomerList);
  RETURN $FirstCustomer;
END;
/

CREATE MICROFLOW MfTest.M028_DataForm_Getter_3 ()
RETURNS MfTest.Customer AS $FirstCustomer
BEGIN
  RETRIEVE $CustomerList FROM MfTest.Customer
    WHERE (starts-with(Name, 'a'))
    SORT BY MfTest.Customer.Name ASC, MfTest.Customer.Email DESC
    LIMIT 2 +1
    OFFSET 3 + 3;
  $FirstCustomer = HEAD($CustomerList);
  RETURN $FirstCustomer;
END;
/

CREATE MICROFLOW MfTest.M028_DataForm_Getter_4 ()
RETURNS MfTest.Customer AS $FirstCustomer
BEGIN
  DECLARE $Lim Long = 3;
  DECLARE $Off Long = 5;
  RETRIEVE $CustomerList FROM MfTest.Customer
    WHERE (starts-with(Name, 'a'))
    SORT BY MfTest.Customer.Name ASC, MfTest.Customer.Email DESC
    LIMIT $Lim
    OFFSET $Off;
  $FirstCustomer = HEAD($CustomerList);
  RETURN $FirstCustomer;
END;
/

-- MARK: Real World

-- ============================================================================
-- LEVEL 8: Complex Real-World Microflows
-- ============================================================================

/**
 * Example 8.1: Order processing workflow
 *
 * Complete order processing with error handling.
 */
CREATE MICROFLOW MfTest.M029_ProcessOrder (
  $OrderNumber: String
)
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;

  -- Find the order
  RETRIEVE $Order FROM MfTest.Order
    WHERE OrderNumber = $OrderNumber
    LIMIT 1;

  -- Validate order exists
  IF $Order = empty THEN
    LOG WARNING NODE 'OrderService' 'Order not found: ' + $OrderNumber;
    RETURN false;
  END IF;

  -- Update order status
  CHANGE $Order (
    Status = 'PROCESSING',
    ProcessedDate = [%CurrentDateTime%]);

  COMMIT $Order WITH EVENTS;

  LOG INFO NODE 'OrderService' 'Order processed: ' + $OrderNumber;
  SET $Success = true;
  RETURN $Success;
END;
/

/**
 * Example 8.2: Batch processing with counter
 *
 * Batch process all active products.
 */
CREATE MICROFLOW MfTest.M030_BatchProcessProducts ()
RETURNS Integer AS $ProcessedCount
BEGIN
  DECLARE $ProcessedCount Integer = 0;

  -- Get all active products
  RETRIEVE $ProductList FROM MfTest.Product
    WHERE IsActive = true;

  -- Process each product
  LOOP $Product IN $ProductList
  BEGIN
    -- Update last processed date
    CHANGE $Product (LastProcessedDate = [%CurrentDateTime%]);
    COMMIT $Product;

    -- Increment counter
    SET $ProcessedCount = $ProcessedCount + 1;

    -- Log progress
    IF $ProcessedCount > 0 THEN
      LOG INFO NODE 'BatchService' 'Processed product count: ' + toString($ProcessedCount);
    END IF;
  END LOOP;

  RETURN $ProcessedCount;
END;
/

/**
 * Example 8.3: Calculation with XPath and div
 *
 * Calculate and update product metrics.
 */
CREATE MICROFLOW MfTest.M031_CalculateProductMetrics (
  $Product: MfTest.Product
)
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;
  DECLARE $DailyAverage Decimal = 0;
  DECLARE $MonthlyTotal Decimal = $Product/MonthlyTotal;

  -- Calculate daily average
  SET $DailyAverage = $MonthlyTotal div 30;

  -- Update product with calculated value using CHANGE
  CHANGE $Product (
    DailyAverage = $DailyAverage,
    LastCalculated = [%CurrentDateTime%]
  );

  COMMIT $Product WITH EVENTS;

  LOG INFO NODE 'MetricsService' 'Metrics calculated for product';
  SET $Success = true;
  RETURN $Success;
END;
/

/**
 * Example 8.4: Multi-step workflow with validation
 *
 * Creates order with validation and linking.
 */
CREATE MICROFLOW MfTest.M032_CreateAndValidateOrder (
  $CustomerCode: String,
  $ProductCode: String,
  $Quantity: Integer
)
RETURNS MfTest.Order AS $NewOrder
BEGIN
  --DECLARE $NewOrder AS MfTest.Order;
  --DECLARE $Customer AS MfTest.Customer;
  --DECLARE $Product AS MfTest.Product;
  DECLARE $TotalPrice Decimal = 0;

  -- Step 1: Find customer
  RETRIEVE $Customer FROM MfTest.Customer
    WHERE Code = $CustomerCode
    LIMIT 1;

  IF $Customer = empty THEN
    LOG ERROR NODE 'OrderService' 'Customer not found: ' + $CustomerCode;
    RETURN empty;
  END IF;

  -- Step 2: Find product
  RETRIEVE $Product FROM MfTest.Product
    WHERE Code = $ProductCode
    LIMIT 1;

  IF $Product = empty THEN
    LOG ERROR NODE 'OrderService' 'Product not found: ' + $ProductCode;
    RETURN empty;
  END IF;

  -- Step 3: Calculate total
  SET $TotalPrice = $Product/Price * $Quantity;

  -- Step 4: Create order
  $NewOrder = CREATE MfTest.Order (
    OrderNumber = 'ORD-' + toString(random() * 10000),
    Quantity = $Quantity,
    TotalPrice = $TotalPrice,
    Status = 'PENDING',
    CreateDate = [%CurrentDateTime%]);

  -- Step 5: Link to customer and product using CHANGE
  CHANGE $NewOrder (
    MfTest.Order_Customer = $Customer,
    MfTest.Order_Product = $Product
  );

  -- Step 6: Save
  COMMIT $NewOrder WITH EVENTS;

  LOG INFO NODE 'OrderService' 'Order created successfully';
  RETURN $NewOrder;
END;
/

/**
 * Example 8.5: Aggregation and reporting
 *
 * Generate report with calculations.
 */
CREATE MICROFLOW MfTest.M033_GenerateProductReport ()
RETURNS Boolean AS $Success
BEGIN
  DECLARE $Success Boolean = false;
  DECLARE $TotalProducts Integer = 0;
  DECLARE $TotalValue Decimal = 0;
  DECLARE $AveragePrice Decimal = 0;

  -- Get all active products
  RETRIEVE $ProductList FROM MfTest.Product
    WHERE IsActive = true;

  -- Calculate metrics
  LOOP $Product IN $ProductList
  BEGIN
    SET $TotalProducts = $TotalProducts + 1;
    SET $TotalValue = $TotalValue + $Product/Price;
  END LOOP;

  -- Calculate average
  IF $TotalProducts > 0 THEN
    SET $AveragePrice = $TotalValue div $TotalProducts;
  END IF;

  -- Log results
  LOG INFO NODE 'ReportService' 'Total products: ' + toString($TotalProducts);
  LOG INFO NODE 'ReportService' 'Average price: ' + toString($AveragePrice);

  SET $Success = true;
  RETURN $Success;
END;
/

-- ============================================================================
-- LEVEL 9: Edge Cases and Advanced Patterns
-- ============================================================================

/**
 * Example 9.1: Empty list handling
 *
 * Safely handle potentially empty lists.
 */
CREATE MICROFLOW MfTest.M034_SafeListProcessing (
  $ProductList: List of MfTest.Product
)
RETURNS Integer AS $Count
BEGIN
  DECLARE $Count Integer = 0;

  IF $ProductList != empty THEN
    LOOP $Product IN $ProductList
    BEGIN
      SET $Count = $Count + 1;
    END LOOP;
  ELSE
    LOG WARNING 'Product list is empty';
  END IF;

  RETURN $Count;
END;
/

/**
 * Example 9.2: Multiple return paths
 *
 * Microflow with different return conditions.
 */
CREATE MICROFLOW MfTest.M035_MultipleReturnPaths (
  $Value: Integer
)
RETURNS String AS $Result
BEGIN
  DECLARE $Result String = 'default';

  IF $Value < 0 THEN
    SET $Result = 'negative';
    RETURN $Result;
  END IF;

  IF $Value = 0 THEN
    SET $Result = 'zero';
    RETURN $Result;
  END IF;

  SET $Result = 'positive';
  RETURN $Result;
END;
/

/**
 * Example 9.3: Empty value comparisons
 *
 * Demonstrates empty checks.
 */
CREATE MICROFLOW MfTest.M036_EmptyValueChecks (
  $Product: MfTest.Product,
  $ProductCode: String
)
RETURNS Boolean AS $IsValid
BEGIN
  DECLARE $IsValid Boolean = true;

  IF $Product = empty THEN
    SET $IsValid = false;
    LOG WARNING 'Product is empty';
    RETURN false;
  END IF;

  IF $ProductCode = empty THEN
    SET $IsValid = false;
    LOG WARNING 'Product code is empty';
    RETURN false;
  END IF;

  RETURN $IsValid;
END;
/

/**
 * Example 9.4: Complex boolean expressions
 *
 * Complex AND/OR logic.
 */
CREATE MICROFLOW MfTest.M037_ComplexBooleanLogic (
  $IsActive: Boolean,
  $IsValid: Boolean,
  $HasStock: Boolean
)
RETURNS Boolean AS $CanProcess
BEGIN
  DECLARE $CanProcess Boolean = false;

  -- Complex condition
  IF $IsActive AND $IsValid AND $HasStock THEN
    SET $CanProcess = true;
  END IF;

  RETURN $CanProcess;
END;
/

